      "supported_bearers": ["lora", "ble_maintenance"],
      "default_routes": {
        "event": "critical_alert",
        "state": "sparse_summary",
        "heartbeat": "sleepy_heartbeat"
      },
      "forbidden": {
        "relay": true,
        "wifi_mesh_router": true,
        "bulk": true
      }
    },
    "servo_controller_powered_v1": {
