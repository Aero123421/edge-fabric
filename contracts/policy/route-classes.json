{
  "version": "1.0.0",
  "route_classes": {
    "sleepy_tiny_control": {
      "allowed_bearers": ["lora_direct"],
      "requires_target_role": ["sleepy_leaf"],
      "max_lora_body_bytes": 16,
      "allow_relay": false,
      "service_level": "eventual_next_poll",
      "pending_policy": "newest_wins"
    },
    "maintenance_sync": {
      "allowed_bearers": ["ble_maintenance"],
      "requires_target_role": ["sleepy_leaf"],
      "allow_relay": false,
      "service_level": "maintenance_window"
    },
    "critical_alert": {
      "allowed_bearers": ["wifi", "wifi_ip", "lora_direct"],
      "allow_redundant": true,
      "max_lora_body_bytes": 10,
      "service_level": "best_effort_urgent"
    },
    "redundant_critical": {
      "allowed_bearers": ["wifi", "wifi_ip", "wifi_mesh", "lora_direct", "lora_relay"],
      "allow_relay": true,
      "allow_redundant": true,
      "hop_limit": 2,
      "max_lora_body_bytes": 10,
      "service_level": "best_effort_urgent"
    },
    "lora_relay_1": {
      "allowed_bearers": ["lora_relay"],
      "requires_target_role": ["lora_relay"],
      "allow_relay": true,
      "allow_redundant": false,
      "hop_limit": 1,
      "max_lora_body_bytes": 6,
      "service_level": "one_hop_relay"
    },
    "wifi_mesh_backbone": {
      "allowed_bearers": ["wifi_mesh"],
      "requires_target_role": ["mesh_router", "mesh_root", "dual_bearer_bridge"],
      "allow_relay": true,
      "allow_redundant": false,
      "service_level": "mesh_backbone"
    },
    "sparse_summary": {
      "allowed_bearers": ["lora_direct", "wifi", "wifi_ip"],
      "allow_redundant": false,
      "service_level": "eventual_summary"
    },
    "sleepy_heartbeat": {
      "allowed_bearers": ["lora_direct", "wifi", "wifi_ip"],
      "requires_target_role": ["sleepy_leaf"],
      "allow_redundant": false,
      "max_lora_body_bytes": 10,
      "service_level": "sleepy_liveness"
    },
    "normal_state": {
      "allowed_bearers": ["wifi", "wifi_ip", "lora_direct"],
      "allow_redundant": false,
      "max_lora_body_bytes": 10,
      "service_level": "normal_state"
    },
    "control_event": {
      "allowed_bearers": ["wifi", "wifi_ip"],
      "forbidden_bearers": ["lora", "lora_direct"],
      "service_level": "control_event"
    },
    "bulk_wifi_only": {
      "allowed_bearers": ["wifi", "wifi_ip", "wifi_mesh"],
      "forbidden_bearers": ["lora", "lora_direct", "lora_relay"],
      "service_level": "bulk_maintenance"
    },
    "local_control": {
      "allowed_bearers": ["wifi", "wifi_ip", "usb_cdc"],
      "forbidden_bearers": ["lora", "lora_direct"],
      "service_level": "low_latency_local"
    }
  }
}
