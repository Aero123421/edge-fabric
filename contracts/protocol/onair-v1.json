{
  "version": "1.0.0",
  "track": "mainline",
  "header": {
    "version": 1,
    "size_bytes": 8,
    "sequence_semantics": "8-bit short-term duplicate hint scoped by source_short_id/logical_type/body hash; not a global message id",
    "fields": [
      "version",
      "logical_type",
      "flags",
      "sequence",
      "source_short_id_le16",
      "target_short_id_le16"
    ]
  },
  "flags": {
    "summary": 1,
    "relay_extension": 2
  },
  "logical_types": {
    "1": {
      "name": "state",
      "body_size_bytes": 3,
      "summary_supported": true,
      "implementation_status": "active"
    },
    "2": {
      "name": "event",
      "body_size_bytes": 4,
      "summary_supported": true,
      "implementation_status": "active"
    },
    "3": {
      "name": "command_result",
      "body_size_bytes": 4,
      "summary_supported": true,
      "implementation_status": "active"
    },
    "4": {
      "name": "pending_digest",
      "body_size_bytes": 2,
      "summary_supported": true,
      "implementation_status": "active"
    },
    "5": {
      "name": "tiny_poll",
      "body_size_bytes": 1,
      "summary_supported": false,
      "implementation_status": "active"
    },
    "6": {
      "name": "compact_command",
      "body_size_bytes": 5,
      "summary_supported": true,
      "implementation_status": "active"
    },
    "7": {
      "name": "heartbeat",
      "body_size_bytes": 5,
      "summary_supported": true,
      "implementation_status": "active"
    }
  },
  "relay_extension": {
    "version": "relay_extension_v1",
    "implementation_status": "active",
    "size_bytes": 7,
    "presence": "present when flags.relay_extension is set; bytes are placed after the base header and before the logical body",
    "fields": [
      "origin_short_id_le16",
      "previous_hop_short_id_le16",
      "ttl",
      "hop_count",
      "route_hint"
    ]
  },
  "state": {
    "keys": {
      "1": "node.power"
    },
    "values": {
      "0": "unknown",
      "1": "awake",
      "2": "sleep"
    }
  },
  "event": {
    "body_layout": [
      "event_code:u8",
      "severity:u8",
      "value_bucket:u8",
      "flags:u8"
    ],
    "codes": {
      "1": "battery_low",
      "2": "motion_detected",
      "3": "leak_detected",
      "4": "tamper",
      "5": "threshold_crossed"
    },
    "severity": {
      "1": "info",
      "2": "warning",
      "3": "critical"
    },
    "flags": {
      "1": "event_wake",
      "2": "latched"
    }
  },
  "heartbeat": {
    "body_layout": [
      "health:u8",
      "battery_bucket:u8",
      "link_quality:u8",
      "uptime_bucket:u8",
      "flags:u8"
    ],
    "health": {
      "1": "ok",
      "2": "degraded",
      "3": "critical"
    },
    "flags": {
      "1": "event_wake",
      "2": "maintenance_awake",
      "4": "low_power"
    }
  },
  "compact_command": {
    "kinds": {
      "1": "maintenance_on",
      "2": "maintenance_off",
      "3": "threshold.set",
      "4": "quiet.set",
      "5": "alarm.clear",
      "6": "sampling.set"
    }
  },
  "command_result": {
    "phases": {
      "1": "accepted",
      "2": "executing",
      "3": "succeeded",
      "4": "failed",
      "5": "rejected",
      "6": "expired"
    },
    "reasons": {
      "1": "ok",
      "2": "svc",
      "3": "maintenance",
      "4": "stale",
      "5": "badcmd",
      "6": "unsupported"
    }
  },
  "tiny_poll": {
    "service_levels": {
      "1": "eventual_next_poll"
    }
  },
  "pending_digest": {
    "flags": {
      "1": "urgent",
      "2": "expires_soon"
    }
  }
}
