{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CommandPayload",
  "type": "object",
  "required": [
    "command_name",
    "args"
  ],
  "properties": {
    "command_name": {
      "type": "string"
    },
    "args": {
      "type": "object"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "requested_by": {
      "type": "string"
    },
    "idempotency_key": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
